{
  "version": 2,
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index?__pathname=/api/$1"
    },
    {
      "source": "/u/(.*)",
      "destination": "/api/index?__pathname=/u/$1"
    }
  ]
}